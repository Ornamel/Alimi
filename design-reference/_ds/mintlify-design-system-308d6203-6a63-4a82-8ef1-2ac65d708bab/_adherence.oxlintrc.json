{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/badges/**",
              "components/buttons/**",
              "components/cards/**",
              "components/code/**",
              "components/docs/**",
              "components/forms/**",
              "components/hero/**",
              "components/navigation/**",
              "components/tabs/**",
              "ui_kits/marketing-site/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Geist Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, Geist Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconOnly|disabled|children|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconOnly, disabled, children, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md)$/]",
        "message": "<Button> size must be one of 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CodeBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:language|code|filename|style|key|ref|className|style|children)$/]",
        "message": "<CodeBlock> doesn't accept that prop. Declared props: language, code, filename, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SidebarSection'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|items|key|ref|className|style|children)$/]",
        "message": "<SidebarSection> doesn't accept that prop. Declared props: title, items."
      },
      {
        "selector": "JSXOpeningElement[name.name='HeroSky'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|headline|subtitle|children|style|key|ref|className|style|children)$/]",
        "message": "<HeroSky> doesn't accept that prop. Declared props: eyebrow, headline, subtitle, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MarketingNav'] > JSXAttribute > JSXIdentifier[name!=/^(?:links|style|key|ref|className|style|children)$/]",
        "message": "<MarketingNav> doesn't accept that prop. Declared props: links, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|icon|style|key|ref|className|style|children)$/]",
        "message": "<SearchPill> doesn't accept that prop. Declared props: placeholder, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedTabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabs|defaultIndex|onChange|style|key|ref|className|style|children)$/]",
        "message": "<SegmentedTabs> doesn't accept that prop. Declared props: tabs, defaultIndex, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|required|placeholder|defaultValue|style|key|ref|className|style|children)$/]",
        "message": "<TextInput> doesn't accept that prop. Declared props: label, required, placeholder, defaultValue, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
